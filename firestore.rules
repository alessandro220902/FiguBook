rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isUser(uid) { return request.auth != null && request.auth.uid == uid; }
    // Azioni sensibili (richieste amicizia, proposte, recensioni, notifiche verso
    // altri) richiedono email verificata: blocca account email/password non
    // verificati. Gli account Google hanno email_verified=true di default.
    function verified() { return request.auth != null && request.auth.token.email_verified == true; }

    // ── Utenti (doc privato + subcollection) ──────────────────────────────
    match /users/{userId} {
      allow read, write: if isUser(userId);

      // Album: owner sempre (read+write). Lettura ad altri utenti loggati se il
      // proprietario e' pubblico (publicProfiles.isPublic) OPPURE se sono amici
      // accettati (friendships). Le rules non ordinano gli uid per costruire il
      // pairId: si provano entrambi gli ordini.
      match /albums/{albumId} {
        allow write: if isUser(userId);
        // Owner sempre. Per gli altri vale (amico O pubblico) E non bloccato dal proprietario.
        allow read: if isUser(userId)
          || (
            (exists(/databases/$(database)/documents/friendships/$(userId + '__' + request.auth.uid))
             || exists(/databases/$(database)/documents/friendships/$(request.auth.uid + '__' + userId))
             || (exists(/databases/$(database)/documents/publicProfiles/$(userId))
                 && get(/databases/$(database)/documents/publicProfiles/$(userId)).data.isPublic == true))
            && !(request.auth.uid in get(/databases/$(database)/documents/users/$(userId)/meta/profile).data.get('blocked', []))
          );
      }
      match /meta/{docId}     { allow read, write: if isUser(userId); }
      // Snapshot statistiche giornaliere: privati, solo il proprietario.
      match /stats/{day}      { allow read, write: if isUser(userId); }
      match /groups/{groupId} { allow read, write: if isUser(userId); }

      // Notifiche: le leggo/segno-lette/cancello io; un ALTRO utente può crearmene
      match /notifications/{notifId} {
        allow read, update, delete: if isUser(userId);
        // Un altro utente puo crearmi una notifica, ma con forma valida e
        // limitata (no payload enormi / pre-lette).
        allow create: if verified()
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.read == false
          && request.resource.data.type is string
          && request.resource.data.title is string
          && request.resource.data.title.size() <= 160
          && (!('info' in request.resource.data)
              || (request.resource.data.info is string && request.resource.data.info.size() <= 160))
          // href solo path interni whitelisted (no javascript:/http: -> anti-XSS)
          && (!('href' in request.resource.data)
              || request.resource.data.href in ['figubook-scambia.html', '/scambi', '/dashboard', '/album', '/community'])
          // icon da set chiuso, non stringa arbitraria iniettabile
          && (!('icon' in request.resource.data)
              || request.resource.data.icon in ['🔄', '✏️', '✅', '👍', '❌', 'ℹ️']);
      }

      // Recensioni RICEVUTE: chiunque autenticato le legge; le lascia un altro utente
      match /feedback/{fid} {
        allow read: if signedIn();
        // Recensione valida solo se esiste uno scambio COMPLETATO tra i due
        // (anti review-bombing). proposalId deve puntare a una proposta
        // completed con entrambi tra i participants.
        allow create, update: if verified()
          && request.resource.data.fromUid == request.auth.uid   // recensisci come te stesso
          && request.auth.uid != userId                          // non recensire te stesso
          && request.resource.data.rating is number
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
          && request.resource.data.comment is string
          && request.resource.data.comment.size() <= 500
          && exists(/databases/$(database)/documents/proposals/$(request.resource.data.proposalId))
          && get(/databases/$(database)/documents/proposals/$(request.resource.data.proposalId)).data.status == 'completed'
          && request.auth.uid in get(/databases/$(database)/documents/proposals/$(request.resource.data.proposalId)).data.participants
          && userId in get(/databases/$(database)/documents/proposals/$(request.resource.data.proposalId)).data.participants;
        allow delete: if false;
      }
    }

    // ── Profili pubblici ──────────────────────────────────────────────────
    match /publicProfiles/{userId} {
      allow read: if signedIn();
      // Solo il proprietario scrive il proprio profilo. Niente piu incremento
      // cross-user di completedTrades (era abusabile); il conteggio scambi si
      // deriva dai feedback ricevuti.
      allow create, update, delete: if isUser(userId);
    }

    // ── Richieste di amicizia: friendRequests/{from__to} ──────────────────
    match /friendRequests/{rid} {
      allow read: if signedIn()
        && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      // Crei solo richieste a tuo nome, non verso te stesso.
      allow create: if verified()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.fromUid != request.resource.data.toUid
        && !(request.resource.data.fromUid in get(/databases/$(database)/documents/users/$(request.resource.data.toUid)/meta/profile).data.get('blocked', []));
      // Mittente (annulla) o destinatario (rifiuta/accetta->delete) la cancellano.
      allow delete: if signedIn()
        && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow update: if false;
    }

    // ── Amicizie: friendships/{pair} = { users:[a,b], requester, accepter } ─
    match /friendships/{pid} {
      allow read: if signedIn() && request.auth.uid in resource.data.users;
      // Solo l'accepter crea, e solo se esiste una richiesta requester->accepter.
      allow create: if signedIn()
        && request.resource.data.accepter == request.auth.uid
        && request.resource.data.users.hasOnly([request.resource.data.requester, request.resource.data.accepter])
        && exists(/databases/$(database)/documents/friendRequests/$(request.resource.data.requester + '__' + request.resource.data.accepter));
      // Entrambi possono sciogliere l'amicizia.
      allow delete: if signedIn() && request.auth.uid in resource.data.users;
      allow update: if false;
    }

    // ── Attribuzione inviti: invites/{invitedUid} = { inviterUid, at } ─────
    match /invites/{invitedUid} {
      // Legge: l'invitato (proprio doc) o l'invitante (per contare i propri).
      allow read: if signedIn()
        && (request.auth.uid == invitedUid
            || request.auth.uid == resource.data.inviterUid);
      // Crea solo il nuovo utente, per sé, con inviterUid != sé, immutabile.
      allow create: if signedIn()
        && request.auth.uid == invitedUid
        && request.resource.data.inviterUid is string
        && request.resource.data.inviterUid.size() > 0
        && request.resource.data.inviterUid != invitedUid
        && request.resource.data.keys().hasOnly(['inviterUid', 'at']);
      allow update, delete: if false;
    }

    // ── Indice username univoci: usernames/{lower} -> { uid } ──────────────
    // Lettura: per check disponibilita + lookup uid da /u/:username.
    match /usernames/{name} {
      allow read: if signedIn();
      // Puoi rivendicare un nome libero solo per te stesso.
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      // Aggiorni/cancelli solo un nome che e' gia tuo (rename libera il vecchio).
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // ── Codici invito gruppo ──────────────────────────────────────────────
    match /inviteCodes/{code} {
      allow read: if signedIn();
      // Crei un codice solo per un gruppo che hai creato tu (no squatting).
      allow create: if signedIn()
        && get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Gruppi di scambio ─────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      // Update consentito solo per:
      //  - join/leave: cambia SOLO memberCount, di esattamente +/-1
      //  - il proprietario: modifica il gruppo senza poter cambiare createdBy
      // (prima era aperto a chiunque -> hijack di nome/codice/contatori)
      allow update: if signedIn() && (
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount'])
          && (request.resource.data.memberCount == resource.data.memberCount + 1
              || request.resource.data.memberCount == resource.data.memberCount - 1))
        || (isUser(resource.data.createdBy)
          && request.resource.data.createdBy == resource.data.createdBy)
      );
      allow delete: if false;

      match /members/{memberId} {
        allow read: if signedIn();
        // gestisci la tua membership; il gruppo deve esistere
        allow create: if isUser(memberId)
          && exists(/databases/$(database)/documents/groups/$(groupId));
        allow update, delete: if isUser(memberId);
      }
      match /inventory/{ownerId} {
        allow read: if signedIn();
        // la tua bacheca, solo se sei membro del gruppo
        allow write: if isUser(ownerId)
          && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(ownerId));
      }
    }

    // ── Proposte di scambio ───────────────────────────────────────────────
    match /proposals/{proposalId} {
      allow read:   if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if verified()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.status == 'pending';   // si nasce sempre pending
      // Un partecipante aggiorna stato/offerta, ma NON puo riscrivere identita
      // o partecipanti (prima poteva alterare qualsiasi campo).
      allow update: if signedIn() && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid
        && request.resource.data.albumId == resource.data.albumId
        && request.resource.data.createdAt == resource.data.createdAt
        // Campi turno coerenti coi partecipanti SE presenti (guardato: i doc
        // vecchi senza questi campi non vengono bloccati; groupId non esiste
        // nel modello e non va vincolato).
        && (!('turnUid' in request.resource.data)
            || request.resource.data.turnUid in resource.data.participants)
        && (!('lastEditedBy' in request.resource.data)
            || request.resource.data.lastEditedBy in resource.data.participants)
        // confirmedBy puo contenere solo partecipanti (no uid finti)
        && request.resource.data.confirmedBy.hasOnly(resource.data.participants)
        // 'completed' SOLO se entrambi i partecipanti hanno confermato
        // (no auto-completamento unilaterale -> anti review-bombing)
        && (request.resource.data.status != 'completed'
            || (request.resource.data.confirmedBy.hasOnly(request.resource.data.participants)
                && request.resource.data.confirmedBy.hasAll(request.resource.data.participants)));
      allow delete: if false;

      match /revisions/{revId} {
        allow read, create: if signedIn();
        allow update, delete: if false;
      }
    }

    // ── Indice scambi per-album (Fase 1) ──────────────────────────────────
    match /tradeIndex/{albumId}/users/{uid} {
      allow read: if signedIn();
      allow write: if isUser(uid);   // pubblichi solo il tuo inventario
    }

    // Tutto il resto: negato di default.
  }
}
